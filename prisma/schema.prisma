generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   @default("admin")
  avatar    String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  address     String?
  city        String?
  country     String   @default("Malta")
  source      String?  @default("website")
  status      String   @default("lead")
  notes       String?
  budgetMin   Float?
  budgetMax   Float?
  avatar      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects   Project[]
  quotes     Quote[]
  messages   Message[]
  documents  Document[]
  expenses   Expense[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  clientId    String
  status      String   @default("planning")
  priority    String   @default("medium")
  budget      Float?
  spent       Float    @default(0)
  startDate   DateTime?
  endDate     DateTime?
  location    String?
  thumbnail   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client     Client     @relation(fields: [clientId], references: [id])
  quotes     Quote[]
  documents  Document[]
  floorplans Floorplan[]
  tasks      Task[]
  moodBoards MoodBoard[]
  expenses   Expense[]
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("todo")
  priority    String   @default("medium")
  assignee    String?
  dueDate     DateTime?
  projectId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id])
}

model Quote {
  id          String   @id @default(cuid())
  projectId   String?
  clientId    String
  title       String
  status      String   @default("draft")
  tier        String   @default("good")
  items       String   @default("[]")
  subtotal    Float    @default(0)
  tax         Float    @default(0)
  total       Float    @default(0)
  validUntil  DateTime?
  notes       String?
  pdfUrl      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client  Client  @relation(fields: [clientId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])
}

model Message {
  id          String   @id @default(cuid())
  clientId    String?
  channel     String   @default("email")
  direction   String   @default("inbound")
  from        String
  to          String?
  subject     String?
  content     String
  status      String   @default("unread")
  isAiGenerated Boolean @default(false)
  attachments String?
  createdAt   DateTime @default(now())

  client Client? @relation(fields: [clientId], references: [id])
}

model Supplier {
  id          String   @id @default(cuid())
  name        String
  category    String
  contact     String?
  email       String?
  phone       String?
  website     String?
  rating      Float    @default(0)
  leadTime    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Floorplan {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  data        String   @default("{}")
  thumbnail   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id])
}

model Document {
  id          String   @id @default(cuid())
  name        String
  type        String
  url         String
  projectId   String?
  clientId    String?
  size        Int?
  createdAt   DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id])
  client  Client?  @relation(fields: [clientId], references: [id])
}

model Activity {
  id          String   @id @default(cuid())
  type        String
  description String
  entityType  String
  entityId    String
  userId      String?
  metadata    String?
  createdAt   DateTime @default(now())
}

model AiConversation {
  id          String   @id @default(cuid())
  title       String
  messages    String   @default("[]")
  type        String   @default("general")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model KnowledgeEntry {
  id        String   @id @default(cuid())
  title     String
  category  String   @default("guides")
  content   String   @default("")
  tags      String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MoodBoard {
  id           String   @id @default(cuid())
  title        String
  description  String?
  projectId    String?
  style        String   @default("contemporary")
  colorPalette String   @default("[]")
  images       String   @default("[]")
  notes        String?
  isPublic     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project Project? @relation(fields: [projectId], references: [id])
}

model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Float
  category    String   @default("materials")
  vendor      String?
  projectId   String?
  clientId    String?
  status      String   @default("pending")
  date        DateTime @default(now())
  receiptUrl  String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project? @relation(fields: [projectId], references: [id])
  client  Client?  @relation(fields: [clientId], references: [id])
}
